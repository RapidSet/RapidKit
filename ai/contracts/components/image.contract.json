{
  "component": "Image",
  "version": "1.0.0",
  "source": "src/components/Image",
  "description": "A lightweight image component with size variants and fallback icon rendering on missing or failed sources.",
  "capabilities": {
    "accessControl": true,
    "fallbackRendering": true,
    "sizeVariants": true,
    "imgPropsForwarding": true
  },
  "props": {
    "src": { "type": "string", "required": false },
    "alt": { "type": "string", "required": false },
    "size": { "type": "\"sm\" | \"md\" | \"lg\"", "required": false },
    "className": { "type": "string", "required": false },
    "loading": { "type": "\"lazy\" | \"eager\"", "required": false },
    "srcSet": { "type": "string", "required": false },
    "access": { "type": "ImageAccessConfig", "required": false },
    "canAccess": {
      "type": "(rule: ImageAccessRule, mode: \"view\") => boolean",
      "required": false
    }
  },
  "states": {
    "hidesWhenViewAccessDenied": "true",
    "rendersFallbackWhenSrcMissing": "true",
    "rendersFallbackWhenImageErrors": "true"
  },
  "accessibility": {
    "altPropForwardedToImg": "true"
  },
  "interaction": {
    "onErrorTriggersFallback": "true"
  },
  "tests": ["src/components/Image/Image.test.tsx"]
}
