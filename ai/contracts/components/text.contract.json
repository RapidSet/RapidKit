{
  "component": "Text",
  "version": "1.0.0",
  "source": "src/components/Text",
  "description": "Presentational text primitive with configurable semantic element, tone, and weight.",
  "capabilities": {
    "accessControl": true,
    "typographyRendering": true,
    "propForwarding": true,
    "semanticElementSelection": true
  },
  "props": {
    "children": { "type": "ReactNode", "required": true },
    "as": {
      "type": "'span' | 'p' | 'small' | 'strong' | 'div'",
      "required": false,
      "default": "'span'"
    },
    "tone": {
      "type": "'default' | 'muted' | 'destructive' | 'success'",
      "required": false,
      "default": "'default'"
    },
    "weight": {
      "type": "'regular' | 'medium' | 'semibold' | 'bold'",
      "required": false,
      "default": "'regular'"
    },
    "truncate": { "type": "boolean", "required": false, "default": "false" },
    "access": { "type": "TextAccessConfig", "required": false },
    "canAccess": {
      "type": "(rule: TextAccessRule, mode: 'view') => boolean",
      "required": false
    }
  },
  "states": {
    "visibleWhenNoAccessConfig": "true",
    "visibleWhenNoResolver": "true",
    "hiddenWhenViewDenied": "true"
  },
  "accessibility": {
    "usesConsumerProvidedSemanticElement": "true"
  },
  "interaction": {
    "nonInteractiveByDefault": "true"
  },
  "tests": ["src/components/Text/Text.test.tsx"]
}
